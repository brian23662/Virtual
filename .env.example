# Resend — for sending the contact form emails
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxx

# Where the form sends quote requests internally.
# Use a real address you can read.
QUOTE_RECIPIENT_EMAIL=info@virtualvri.com

# The verified sender address Resend will send from.
# For the demo you can use Resend's onboarding domain:
#   onboarding@resend.dev
# For production, verify a domain in Resend and use something like:
#   Virtual VRI <hello@virtualvri.com>
RESEND_FROM_EMAIL=Virtual VRI <onboarding@resend.dev>

# Anthropic API key for the "Plain Language" accessibility helper.
# Without this, the button still appears but returns a friendly fallback message.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxx
